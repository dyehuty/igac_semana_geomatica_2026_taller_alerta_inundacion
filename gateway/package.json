{
  "name": "frost-visualization-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js 24 gateway that bridges FROST MQTT messages to a normalized WebSocket stream for visualization clients.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude tests/**/*.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.0",
    "mqtt": "^5.14.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
