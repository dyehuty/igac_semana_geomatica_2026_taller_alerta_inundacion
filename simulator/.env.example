# URL base de la API REST de FROST-Server (OGC SensorThings API v1.1)
FROST_URL=http://localhost:8080/FROST-Server/v1.1

# Puerto del panel de control del simulador (3001 lo usa el gateway)
PORT=3002

# Numero de estaciones a sembrar/simular (max 22; recorta el catalogo para pruebas)
STATION_COUNT=22

# Periodo del bucle base de publicacion de observaciones, en milisegundos
BASE_TICK_MS=2000

# Duracion del evento de tormenta, en milisegundos (120000 = 2 minutos)
STORM_DURATION_MS=120000

# Umbral critico de precipitacion acumulada 24h, en mm
RAIN_THRESHOLD=50

LOG_LEVEL=info
